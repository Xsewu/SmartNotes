generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String            @id @default(uuid())
  /// Email domain should be validated at the application layer:
  /// @stud.prz.edu.pl
  email               String            @unique
  passwordHash        String?
  emailVerified       DateTime?
  studentIndex        String?           @unique
  image               String?
  yearOfStudy         Int?
  studyGroup          String?
  isVerified          Boolean           @default(false)
  role                UserRole          @default(STUDENT)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  accounts            Account[]
  comments            Comment[]
  favorites           Favorite[]
  files               File[]
  flashcardDecks      FlashcardDeck[]
  ratings             Rating[]
  sessions            Session[]
  receivedPermissions SharePermission[] @relation("UserSharePermissions")

  @@map("User")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("Account")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("VerificationToken")
}

model Subject {
  id          Int    @id @default(autoincrement())
  name        String
  yearOfStudy Int
  files       File[]

  @@unique([name, yearOfStudy])
  @@map("Subject")
}

model File {
  id               String            @id @default(uuid())
  title            String
  url              String
  format           String
  visibility       Visibility        @default(PRIVATE)
  createdAt        DateTime          @default(now())
  pages            Int               @default(1)
  authorId         String
  subjectId        Int?
  comments         Comment[]
  favorites        Favorite[]
  author           User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  subject          Subject?          @relation(fields: [subjectId], references: [id])
  tags             FileTag[]
  flashcardDecks   FlashcardDeck[]
  ratings          Rating[]
  sharePermissions SharePermission[]

  @@index([authorId])
  @@index([visibility])
  @@map("File")
}

model Tag {
  id    Int       @id @default(autoincrement())
  name  String    @unique
  files FileTag[]

  @@map("Tag")
}

model FileTag {
  fileId String
  tagId  Int
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([fileId, tagId])
  @@map("FileTag")
}

/// Direct sharing: links a file with one specific recipient user.
model SharePermission {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  fileId      String
  recipientId String
  file        File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  recipient   User     @relation("UserSharePermissions", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([fileId, recipientId])
  @@index([recipientId])
  @@map("SharePermission")
}

model Favorite {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fileId])
}

model Rating {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  value     Int
  userId    String
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fileId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FlashcardDeck {
  id         String      @id @default(uuid())
  title      String
  createdAt  DateTime    @default(now())
  fileId     String
  userId     String
  flashcards Flashcard[]
  file       File        @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("FlashcardDeck")
}

model Flashcard {
  id     String        @id @default(uuid())
  front  String
  back   String
  deckId String
  deck   FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@map("Flashcard")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum Visibility {
  PRIVATE
  DIRECT
  GROUP
  YEAR
}
